# dependencies
/node_modules
/.pnp
.pnp.js

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
#
# Every .env EXCEPT .env.example is ignored. The earlier ".env*.local" pattern
# covered .env.local but not .env.staging or .env.production, so creating either
# of those would have committed live credentials.
.env
.env.*
!.env.example

# typescript
*.tsbuildinfo
next-env.d.ts
.gstack/
