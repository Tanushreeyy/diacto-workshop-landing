# Template only — every value here is a PLACEHOLDER.
#
# This repository is PUBLIC, and Netlify's secrets scanner fails the build when a
# value set in the site's environment also appears in a repo file. Real tenant
# ids, mailbox names and spreadsheet ids therefore do not belong here, even
# though they are identifiers rather than credentials.
#
# Real values live in .env.staging / .env.production, which git ignores.

# ─── Microsoft 365 / Graph — send email as the configured mailbox ───
AZURE_TENANT_ID=<directory-tenant-id>
AZURE_CLIENT_ID=<application-client-id>
AZURE_CLIENT_SECRET=
GRAPH_SENDER_UPN=<mailbox-we-send-as>

# ─── Google Sheets — source of truth (service account) ───
GOOGLE_SERVICE_ACCOUNT_EMAIL=<name>@<project>.iam.gserviceaccount.com
# Paste the private_key with literal \n sequences; code un-escapes them.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
SHEET_ID=<spreadsheet-id-from-the-sheet-url>
# Comma-separated. Each live Instant Form gets its own connection and so its own
# tab; list them all and every one is ingested (deduped globally). Keep the old
# tab listed while an ad swaps over, so no submission is dropped mid-cutover.
# REQUIRED — no defaults. All three tab names must be set explicitly; there is no
# fallback, because the old fallbacks were the PRODUCTION tabs and one forgotten
# variable silently pointed a staging deploy at live leads.
#
# Live Meta form tabs as of 18 July 2026. Each connected Instant Form writes to
# its own tab, so a new ad campaign means a new tab that must be added here or
# its leads are never ingested.
#   Sheet1 · Sheet2 · Campaign2 · VideoSheetV2 (added 17 July)
# Staging uses: form_staging,form_staging_v3
SHEET_FORM_TAB=Sheet1,Sheet2,Campaign2,VideoSheetV2
# Renamed to 'automation_PAUSED' to stop the campaign without a deploy.
SHEET_AUTOMATION_TAB=automation
# Kill switches + the header baseline and mail watermark. A missing TAB still
# means "all on" (control.ts fails open); a missing VARIABLE is refused.
# Staging must use its own: control_staging. Sharing one tab makes the two
# environments fight over the header baseline and the mail watermark.
SHEET_CONTROL_TAB=control
# The calling team's tab. Their Sub Status syncs one-way into `status` each tick,
# so a lead marked Junk on the phone stops being chased. Blank disables the sync.
SHEET_CALLING_TAB=<calling-tab-name>

# ─── Channel kill switches live in the CONTROL TAB, not here ───
#   email_enabled     FALSE -> silences every email, all stages, pass included
#   whatsapp_enabled  FALSE -> silences every WhatsApp, all stages
# Both default to ON when the row is absent, so an older control tab keeps
# working unchanged. Flip them in the sheet — no deploy needed.

# ─── WhatsApp (WATI) ───
WATI_API_ENDPOINT=https://live-mt-server.wati.io/<tenant-id>
WATI_ACCESS_TOKEN=
# WA-5 document header: the header media variable name in the WATI template.
WATI_WA5_DOC_PARAM=pdfLink
# Template names — must match APPROVED WATI templates (override defaults if named differently)
# WATI_TPL_WA1=wa_1_booking_pending   # instant ack
# WATI_TPL_WA2=wa_2_value_nudge       # nurture touch 1
# WATI_TPL_WA3=wa_3_problem_nudge     # nurture touch 2
# WATI_TPL_WA4=wa_4_urgency_nudge     # nurture, repeats 2x/day
# WATI_TPL_WA5=wa_5_confirmation_link  # on booking (pass sent as link)
# Set true only if WATI ever supports a dynamic document header for WA-5:
WA5_NATIVE_DOC=false
# WATI_TPL_WA6=wa_6_day_before        # reminder - 1 day before
# WATI_TPL_WA7=wa_7_morning_of        # reminder - morning of
WATI_TPL_WA8=<wa-8-template-name>   # differs from the default; check WATI

# ─── Slack — REQUIRED in production ───
# notifySlack() no-ops silently when this is empty, which means every alert the
# system raises (damaged-sheet halt, header edited by hand, "X replied — stopped",
# daily-limit skip) goes nowhere. Do not deploy without it.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T05SX1CG13J/B0BGM4KRSKE/xxxx

# ─── Plumbing ───
# Random secret shared with the cron trigger. Generate: openssl rand -hex 24
CRON_SECRET=
# Public base URL of this deployment (no trailing slash)
LANDING_BASE_URL=https://your-app.vercel.app

# ─── For scripts/cron.mjs only (VPS/self-hosted) ───
# TICK_URL=https://your-app/api/cron/tick

# ─── Workshop details (all optional — these are the defaults) ───
# Change EVENT_START_UTC alone and all three reminders move with it
# (day before 10:00 IST, morning of 09:00 IST, 2h before 13:00 IST).
EVENT_START_UTC=2026-07-17T09:30:00Z
EVENT_DATE_LABEL=Friday, 17 July 2026
EVENT_TIME_LABEL=3:00 PM – 6:00 PM  (Check-in from 2:30 PM)
EVENT_VENUE=Prabhavee Tech Park, Baner, Pune
EVENT_MAP_URL=https://maps.app.goo.gl/MtpixrnbfgNFHYku5?g_st=iw
EVENT_MMDD=0717
REG_ID_PREFIX=HPT
SUPPORT_NUMBER=+91 7387731069
BRAND_WEBSITE=www.diacto.com
BRAND_FROM_NAME=Team Diacto Technologies
UNSUBSCRIBE_EMAIL=<mailbox-that-receives-opt-outs>
